{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ge365x-web",
  "main": "src/index.tsx",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": "./dist",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ge365x-web-production",
      "database_id": "44b03d54-c23e-4258-a4f9-00cc397594b6
"
    }
  ],
  "triggers": {
    "crons": [
      "*/1 * * * *",   // 毎分: post_queue 消化
      "*/5 * * * *"    // 5分毎: autopilot 次ターン生成
    ]
  },
  "vars": {
    "OPENAI_MODEL": "gpt-4o-mini",
    "PAYPAL_MODE": "sandbox"
  }
  // secrets は Cloudflare ダッシュボード / wrangler secret put で設定:
  //   JWT_SECRET, ENCRYPTION_KEY, ADMIN_PASSWORD,
  //   OPENAI_API_KEY, GEMINI_API_KEY,
  //   STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET,
  //   PAYPAL_CLIENT_ID, PAYPAL_SECRET,
  //   TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID,
  //   X_API_KEY, X_API_SECRET, X_BEARER_TOKEN,
  //   X_CLIENT_ID, X_CLIENT_SECRET, X_OAUTH_REDIRECT_URL
}
