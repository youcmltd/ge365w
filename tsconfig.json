{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "types": ["@cloudflare/workers-types"],
    "lib": ["ESNext"],
    "allowJs": false,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": ["src/**/*", "vite.config.ts"]
}
